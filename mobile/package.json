{
  "name": "@birdogey/mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint src app app.config.ts",
    "lint:fix": "eslint src app app.config.ts --fix",
    "typecheck": "tsc --noEmit",
    "eas-build-post-install": "echo '[post-install] writing .env.production from EAS env' && : ${API_BASE_URL:?missing in EAS env} && : ${IMAGEKIT_URL:?missing in EAS env} && : ${IMAGEKIT_PUBLIC_KEY:?missing in EAS env} && printf 'NODE_ENV=production\\nAPI_BASE_URL=%s\\nIMAGEKIT_URL=%s\\nIMAGEKIT_PUBLIC_KEY=%s\\n' \"$API_BASE_URL\" \"$IMAGEKIT_URL\" \"$IMAGEKIT_PUBLIC_KEY\" > .env.production && echo '[post-install] .env.production written:' && cat .env.production && mkdir -p ios && cp .env.schema ios/.env.schema && cp .env.production ios/.env.production && echo '[post-install] copied .env.schema + .env.production into ios/ so varlock finds them when bundle phase runs from ios/' && cd .. && npm run build -w shared",
    "eas-build": "eas build -p ios --profile production --non-interactive",
    "eas-deploy": "eas submit -p ios --latest --non-interactive"
  },
  "dependencies": {
    "@birdogey/shared": "*",
    "@react-native-picker/picker": "2.11.4",
    "@sentry/react-native": "^8.10.0",
    "@tanstack/react-query": "^5.90.21",
    "@varlock/expo-integration": "^1.1.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "date-fns": "^4.1.0",
    "expo": "^55.0.0",
    "expo-constants": "^55.0.7",
    "expo-dev-client": "~55.0.27",
    "expo-document-picker": "~55.0.13",
    "expo-font": "~55.0.4",
    "expo-image-picker": "~55.0.18",
    "expo-linking": "~55.0.9",
    "expo-local-authentication": "~55.0.13",
    "expo-router": "~55.0.8",
    "expo-secure-store": "~55.0.9",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "imagekit-javascript": "^4.0.1",
    "intl-pluralrules": "^2.0.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "^0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.2",
    "varlock": "^1.2.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^55.0.10",
    "typescript": "~5.9.2"
  },
  "private": true
}
