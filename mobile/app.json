{
  "expo": {
    "name": "Birdogey",
    "slug": "birdogey",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "birdogey",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stackoverfloweth.birdogey",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "Allow Birdogey to use Face ID for sign-in.",
        "NSPhotoLibraryUsageDescription": "Allow Birdogey to access your photos so you can set a player image."
      },
      "buildNumber": "6"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.stackoverfloweth.birdogey"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "2b899818-73f2-481b-939f-348138487e68"
      }
    }
  }
}
